{
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.js"
    },
    {
      "source": "/checkout",
      "destination": "/checkout.html"
    },
    {
      "source": "/success",
      "destination": "/success.html"
    },
    {
      "source": "/tokushoho",
      "destination": "/tokushoho.html"
    }
  ]
}
