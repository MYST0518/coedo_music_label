# Environment Variables — DO NOT COMMIT THIS FILE

# Square Sandbox (Test) Credentials
# Get from: https://developer.squareup.com/apps
SQUARE_ACCESS_TOKEN=YOUR_SANDBOX_ACCESS_TOKEN_HERE
SQUARE_APPLICATION_ID=YOUR_SANDBOX_APPLICATION_ID_HERE
SQUARE_LOCATION_ID=YOUR_SANDBOX_LOCATION_ID_HERE
SQUARE_ENVIRONMENT=sandbox

# Server Settings
PORT=3000
NODE_ENV=development

# CORS — Your frontend domain (Vercel deployment URL)
ALLOWED_ORIGIN=http://localhost:3000

# Session/CSRF Secret (generate a random 32+ char string)
SESSION_SECRET=CHANGE_THIS_TO_A_RANDOM_SECRET_STRING_32CHARS_MIN
